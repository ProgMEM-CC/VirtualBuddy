#!/bin/bash
#
# VirtualBuddy Linux Guest Additions - Resolution Fallback Script
#
# This script provides fallback resolution handling when spice-vdagent
# encounters issues with the SPICE protocol. It monitors for vdagent
# errors and applies xrandr fixes automatically.
#
# It also provides manual resolution commands for non-GNOME desktops.
#
# Usage:
#   virtualbuddy-resolution              # Run in monitor mode (for systemd)
#   virtualbuddy-resolution --set WxH    # Set resolution manually
#   virtualbuddy-resolution --auto       # Auto-detect and apply best resolution
#   virtualbuddy-resolution --list       # List available resolutions
#

set -euo pipefail

VERSION="1.3.0"

# Colors for terminal output (disabled if not a TTY)
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    BLUE='\033[0;34m'
    CYAN='\033[0;36m'
    BOLD='\033[1m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    YELLOW=''
    BLUE=''
    CYAN=''
    BOLD=''
    NC=''
fi

log() {
    echo -e "${CYAN}[virtualbuddy-resolution]${NC} $*"
}

log_success() {
    echo -e "${GREEN}✓${NC} $*"
}

log_warning() {
    echo -e "${YELLOW}⚠${NC} $*"
}

log_error() {
    echo -e "${RED}${BOLD}ERROR:${NC} $*" >&2
}

# Detect display server type
detect_display_server() {
    if [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
        echo "wayland"
    elif [[ -n "${DISPLAY:-}" ]]; then
        echo "x11"
    else
        echo "none"
    fi
}

# Detect desktop environment
detect_desktop_environment() {
    local de="${XDG_CURRENT_DESKTOP:-}"
    if [[ -z "$de" ]]; then
        de="${DESKTOP_SESSION:-}"
    fi
    echo "$de" | tr '[:upper:]' '[:lower:]'
}

# Get the primary output name for X11
get_x11_output() {
    if command -v xrandr &>/dev/null; then
        xrandr 2>/dev/null | grep " connected" | head -1 | cut -d' ' -f1
    fi
}

# Get current resolution
get_current_resolution() {
    local display_server
    display_server=$(detect_display_server)

    case "$display_server" in
        x11)
            if command -v xrandr &>/dev/null; then
                xrandr 2>/dev/null | grep '\*' | head -1 | awk '{print $1}'
            fi
            ;;
        wayland)
            # Try various Wayland tools
            if command -v wlr-randr &>/dev/null; then
                wlr-randr 2>/dev/null | grep "current" | head -1 | awk '{print $1}'
            elif command -v gnome-randr &>/dev/null; then
                gnome-randr 2>/dev/null | grep "current" | head -1 | awk '{print $1}'
            elif command -v kscreen-doctor &>/dev/null; then
                kscreen-doctor -o 2>/dev/null | grep -oP '\d+x\d+' | head -1
            fi
            ;;
    esac
}

# List available resolutions
list_resolutions() {
    local display_server
    display_server=$(detect_display_server)

    echo -e "${BOLD}Available Resolutions:${NC}"
    echo ""

    case "$display_server" in
        x11)
            if command -v xrandr &>/dev/null; then
                local output
                output=$(get_x11_output)
                echo "Output: $output"
                echo ""
                xrandr 2>/dev/null | grep -A 100 "^$output" | grep -E "^\s+[0-9]+" | head -20
            else
                log_error "xrandr not found"
            fi
            ;;
        wayland)
            if command -v wlr-randr &>/dev/null; then
                wlr-randr 2>/dev/null
            elif command -v gnome-randr &>/dev/null; then
                gnome-randr 2>/dev/null
            elif command -v kscreen-doctor &>/dev/null; then
                kscreen-doctor -o 2>/dev/null
            else
                log_error "No Wayland resolution tool found (wlr-randr, gnome-randr, or kscreen-doctor)"
            fi
            ;;
        none)
            log_error "No display server detected"
            ;;
    esac
}

# Set resolution on X11
set_resolution_x11() {
    local resolution="$1"
    local output
    output=$(get_x11_output)

    if [[ -z "$output" ]]; then
        log_error "Could not detect X11 output"
        return 1
    fi

    local width height
    width=$(echo "$resolution" | cut -d'x' -f1)
    height=$(echo "$resolution" | cut -d'x' -f2)

    # Check if mode already exists
    if xrandr 2>/dev/null | grep -q "$resolution"; then
        log "Setting resolution to $resolution on $output"
        xrandr --output "$output" --mode "$resolution" 2>/dev/null && {
            log_success "Resolution set to $resolution"
            return 0
        }
    fi

    # Try to create the mode if it doesn't exist
    log "Mode $resolution not found, attempting to create it..."

    if command -v cvt &>/dev/null; then
        local modeline
        modeline=$(cvt "$width" "$height" 60 2>/dev/null | grep "Modeline" | cut -d' ' -f2-)

        if [[ -n "$modeline" ]]; then
            local mode_name
            mode_name=$(echo "$modeline" | awk '{print $1}' | tr -d '"')

            # Create and add the mode
            xrandr --newmode $modeline 2>/dev/null || true
            xrandr --addmode "$output" "$mode_name" 2>/dev/null || true
            xrandr --output "$output" --mode "$mode_name" 2>/dev/null && {
                log_success "Created and set custom mode $mode_name"
                return 0
            }
        fi
    fi

    log_error "Failed to set resolution $resolution"
    return 1
}

# Set resolution on Wayland
set_resolution_wayland() {
    local resolution="$1"
    local de
    de=$(detect_desktop_environment)

    log "Detected desktop environment: $de"

    # GNOME
    if [[ "$de" == *"gnome"* ]] && command -v gnome-randr &>/dev/null; then
        log "Using gnome-randr..."
        gnome-randr modify --mode "$resolution" 2>/dev/null && {
            log_success "Resolution set to $resolution"
            return 0
        }
    fi

    # KDE Plasma
    if [[ "$de" == *"kde"* ]] || [[ "$de" == *"plasma"* ]]; then
        if command -v kscreen-doctor &>/dev/null; then
            log "Using kscreen-doctor..."
            local output
            output=$(kscreen-doctor -o 2>/dev/null | grep -oP 'Output: \d+ \K\S+' | head -1)
            if [[ -n "$output" ]]; then
                kscreen-doctor output."$output".mode."${resolution}@60" 2>/dev/null && {
                    log_success "Resolution set to $resolution"
                    return 0
                }
            fi
        fi
    fi

    # wlroots-based compositors (Sway, Hyprland, etc.)
    if command -v wlr-randr &>/dev/null; then
        log "Using wlr-randr..."
        local output
        output=$(wlr-randr 2>/dev/null | grep -oP '^\S+' | head -1)
        if [[ -n "$output" ]]; then
            wlr-randr --output "$output" --custom-mode "$resolution" 2>/dev/null && {
                log_success "Resolution set to $resolution"
                return 0
            }
            # Try without custom-mode
            wlr-randr --output "$output" --mode "$resolution" 2>/dev/null && {
                log_success "Resolution set to $resolution"
                return 0
            }
        fi
    fi

    log_error "Could not set Wayland resolution. Try installing gnome-randr, kscreen-doctor, or wlr-randr."
    return 1
}

# Set resolution (auto-detect display server)
set_resolution() {
    local resolution="$1"

    # Validate resolution format
    if ! [[ "$resolution" =~ ^[0-9]+x[0-9]+$ ]]; then
        log_error "Invalid resolution format: $resolution (expected WxH, e.g., 1920x1080)"
        return 1
    fi

    local display_server
    display_server=$(detect_display_server)

    case "$display_server" in
        x11)
            set_resolution_x11 "$resolution"
            ;;
        wayland)
            set_resolution_wayland "$resolution"
            ;;
        none)
            log_error "No display server detected"
            return 1
            ;;
    esac
}

# Auto-detect and apply resolution based on xrandr --auto
auto_resolution() {
    local display_server
    display_server=$(detect_display_server)

    case "$display_server" in
        x11)
            local output
            output=$(get_x11_output)
            if [[ -n "$output" ]]; then
                log "Running xrandr --auto for $output..."
                xrandr --output "$output" --auto 2>/dev/null && {
                    local new_res
                    new_res=$(get_current_resolution)
                    log_success "Resolution set to $new_res"
                    return 0
                }
            fi
            log_error "Failed to auto-configure resolution"
            return 1
            ;;
        wayland)
            log_warning "Auto-resolution not supported on Wayland"
            log "Use --set WxH to set a specific resolution"
            return 1
            ;;
        none)
            log_error "No display server detected"
            return 1
            ;;
    esac
}

# Monitor spice-vdagentd for errors and apply fixes
monitor_vdagent() {
    log "Starting spice-vdagent error monitor..."
    log "Will apply xrandr fix when protocol errors are detected"

    # Wait a bit for the desktop to fully initialize
    sleep 3

    local display_server
    display_server=$(detect_display_server)

    if [[ "$display_server" != "x11" ]]; then
        log "Monitor mode only works on X11 (detected: $display_server)"
        log "For Wayland, spice-vdagent should work automatically with your compositor"
        exit 0
    fi

    # Monitor journalctl for spice-vdagentd errors
    journalctl -fu spice-vdagentd --no-pager 2>/dev/null | while read -r line; do
        if echo "$line" | grep -q "invalid message size"; then
            log_warning "Detected spice-vdagent protocol error"
            log "Applying xrandr workaround..."

            # Small delay to let things settle
            sleep 0.5

            local output
            output=$(get_x11_output)
            if [[ -n "$output" ]]; then
                xrandr --output "$output" --auto 2>/dev/null && {
                    local new_res
                    new_res=$(get_current_resolution)
                    log_success "Applied workaround, resolution: $new_res"
                }
            fi
        fi
    done
}

# Show help
show_help() {
    echo "VirtualBuddy Resolution Helper v$VERSION"
    echo ""
    echo "Usage: virtualbuddy-resolution [OPTION]"
    echo ""
    echo "Options:"
    echo "  --set WxH     Set resolution (e.g., --set 1920x1080)"
    echo "  --auto        Auto-detect and apply best resolution (X11 only)"
    echo "  --list        List available resolutions"
    echo "  --monitor     Monitor spice-vdagent for errors (for systemd service)"
    echo "  --version     Show version"
    echo "  --help        Show this help"
    echo ""
    echo "Examples:"
    echo "  virtualbuddy-resolution --set 1920x1080"
    echo "  virtualbuddy-resolution --auto"
    echo "  virtualbuddy-resolution --list"
    echo ""
    echo "Display server: $(detect_display_server)"
    echo "Desktop environment: $(detect_desktop_environment)"
    echo "Current resolution: $(get_current_resolution)"
    echo ""
}

# Main
main() {
    case "${1:-}" in
        --set)
            if [[ -z "${2:-}" ]]; then
                log_error "Missing resolution argument"
                echo "Usage: virtualbuddy-resolution --set WxH"
                exit 1
            fi
            set_resolution "$2"
            ;;
        --auto)
            auto_resolution
            ;;
        --list)
            list_resolutions
            ;;
        --monitor)
            monitor_vdagent
            ;;
        --version)
            echo "virtualbuddy-resolution version $VERSION"
            ;;
        --help|-h)
            show_help
            ;;
        "")
            # Default: run in monitor mode (for systemd)
            monitor_vdagent
            ;;
        *)
            log_error "Unknown option: $1"
            show_help
            exit 1
            ;;
    esac
}

main "$@"
